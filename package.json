{
  "name": "hm",
  "version": "1.0.0",
  "description": "Write shell command in natural language and hm generates the command for you using AI.",
  "author": "Arndt Voges",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/arndtvoges/hm.git"
  },
  "keywords": ["cli", "shell", "ai", "natural-language", "terminal"],
  "type": "module",
  "bin": {
    "hm": "src/cli.ts"
  },
  "scripts": {
    "dev": "bun run src/cli.ts",
    "build": "bun build src/cli.ts --compile --outfile hm",
    "demo": "vhs demo.tape"
  },
  "engines": {
    "bun": ">=1.1.0"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.71",
    "@anthropic-ai/sdk": "^0.78.0"
  },
  "devDependencies": {
    "bun-types": "^1.3.10"
  }
}
