{
  "name": "hm",
  "version": "1.1.0",
  "description": "Write shell command in natural language and hm generates the command for you using AI.",
  "author": "Arndt Voges",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/arndtvoges/hm.git"
  },
  "keywords": ["cli", "shell", "ai", "natural-language", "terminal"],
  "type": "module",
  "bin": {
    "hm": "src/cli.ts"
  },
  "scripts": {
    "dev": "bun run src/cli.ts",
    "build": "bun build src/cli.ts --compile --outfile hm",
    "test": "bun test",
    "test:unit": "bun test test/provider.test.ts test/shell.test.ts test/agent.test.ts",
    "test:live": "bun test test/api.test.ts test/cli.test.ts",
    "lint": "biome check src/ test/",
    "lint:fix": "biome check --write src/ test/",
    "format": "biome format --write src/ test/",
    "format:check": "biome format --check src/ test/",
    "demo": "vhs demo.tape"
  },
  "engines": {
    "bun": ">=1.1.0"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.72",
    "@anthropic-ai/sdk": "^0.78.0",
    "openai": "^6.33.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "bun-types": "^1.3.10",
    "lefthook": "^2.1.4"
  }
}
